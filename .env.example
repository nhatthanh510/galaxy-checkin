# Supabase (client-side, safe to expose the anon key — RLS enforces access).
# Copy to .env and fill in from your Supabase project settings.
# The kiosk currently runs on mock data, so these are only needed once the
# query hooks in src/lib/queries/ are switched from mock to Supabase.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
